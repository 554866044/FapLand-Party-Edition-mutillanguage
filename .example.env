# SQLite/LibSQL connection string used by the Electron app for local persistence.
# Leave unset to use the default local database file at `file:dev.db`.
DATABASE_URL="file:dev.db"

# GitHub repository slug used by the app updater, for example `owner/repo`.
# The packaged CI build sets this automatically; set it locally if you want update checks to target a repo.
FLAND_UPDATE_REPOSITORY="owner/repo"

# Built-in online multiplayer server shown to users in the server list.
# Override these when you want the app to point at your hosted Supabase project by default.
VITE_MULTIPLAYER_DEFAULT_SUPABASE_URL="https://example.supabase.co"
VITE_MULTIPLAYER_DEFAULT_SUPABASE_ANON_KEY="public-anon-key-placeholder"

# Local development multiplayer server profile.
# These are used for the extra development server entry that appears when dev features are enabled.
VITE_MULTIPLAYER_DEVELOPMENT_SUPABASE_URL="http://127.0.0.1:54321"
VITE_MULTIPLAYER_DEVELOPMENT_SUPABASE_ANON_KEY="your-local-supabase-anon-key"

# Supabase Discord OAuth for multiplayer account linking.
# When configured on a server, the app will require players to link Discord and the Discord account must expose an email.
SUPABASE_AUTH_EXTERNAL_DISCORD_CLIENT_ID=""
SUPABASE_AUTH_EXTERNAL_DISCORD_SECRET=""

# Enables dev-only app features outside normal Vite dev mode.
# Accepted truthy values are `true` and `1`.
# FLAND_ENABLE_DEV_FEATURES="false"

# Legacy/alternate development flag checked by the game overlay.
# Set to `development` if you need debug round controls without changing other feature flags.
VITE_GAME_ENV="production"

# Build profile used by `vite.config.ts`.
# Use `release` for hardened release builds, otherwise keep `default`.
FLAND_BUILD_PROFILE="default"

# Enables compressed bundle size reporting during builds.
# Accepted truthy values are `true` and `1`.
FLAND_BUILD_ANALYZE="false"

# Controls whether each Electron/Vite target is obfuscated during release-style builds.
# Accepted truthy values are `true` and `1`. By default these follow the selected build profile.
FLAND_OBFUSCATE_RENDERER="false"
FLAND_OBFUSCATE_PRELOAD="false"
FLAND_OBFUSCATE_MAIN="false"

# Overrides the renderer URL used by Electron in development.
# Usually set automatically by Vite or `scripts/dev-multiplayer.sh`; only set this manually for custom dev wiring.
# VITE_DEV_SERVER_URL="http://127.0.0.1:3000"

# Adds a suffix to Electron's user-data directory so multiple local clients can run with isolated state.
# Useful for multiplayer testing.
# FLAND_USER_DATA_SUFFIX="mp1"

# `npm run dev:multiplayer` helper script settings.
# `FLAND_MP_PORT` is the preferred starting Vite port and `FLAND_MP_MAX_PORT_SCAN` controls how far the script searches.
# FLAND_MP_PORT="3000"
# FLAND_MP_MAX_PORT_SCAN="100"
